<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Portfolio</title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #0a0a0a;
      color: white;
      scroll-behavior: smooth;
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0;
      width: 100%;
      display: flex;
      justify-content: space-between;
      padding: 20px 40px;
      background: rgba(0,0,0,0.4);
      backdrop-filter: blur(10px);
      z-index: 1000;
    }

    nav a {
      color: #aaa;
      text-decoration: none;
      margin-left: 20px;
    }

    nav a:hover {
      color: white;
    }

    /* HERO */
    .hero {
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 0 20px;
      background: radial-gradient(circle at top, #1a1a1a, #0a0a0a);
    }

    .hero h1 {
      font-size: 56px;
      line-height: 1.1;
      margin: 20px 0;
    }

    .subtitle {
      color: #888;
      letter-spacing: 2px;
      text-transform: uppercase;
      font-size: 12px;
    }

    .description {
      color: #aaa;
      max-width: 600px;
      margin: 0 auto;
    }

    .buttons {
      margin-top: 30px;
    }

    .btn {
      padding: 12px 20px;
      border-radius: 12px;
      text-decoration: none;
      margin: 0 10px;
      display: inline-block;
      transition: 0.3s;
    }

    .btn.primary {
      background: white;
      color: black;
    }

    .btn.secondary {
      border: 1px solid #333;
      color: white;
    }

    .btn:hover {
      transform: translateY(-3px);
    }

    /* SECTIONS */
    section {
      padding: 100px 20px;
      max-width: 1100px;
      margin: auto;
    }

    h2 {
      font-size: 36px;
      margin-bottom: 40px;
    }

    /* PROJECTS */
    .projects {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
    }

    .project-card {
      background: #111;
      border-radius: 16px;
      overflow: hidden;
      transition: 0.4s;
      opacity: 0;
      transform: translateY(30px);
    }

    .project-card.show {
      opacity: 1;
      transform: translateY(0);
    }

    .project-card:hover {
      transform: translateY(-8px);
    }

    .project-card img {
      width: 100%;
      height: 180px;
      object-fit: cover;
    }

    .project-info {
      padding: 15px;
    }

    .tags span {
      font-size: 12px;
      background: #222;
      padding: 4px 8px;
      border-radius: 8px;
      margin-right: 5px;
    }

    .link {
      display: inline-block;
      margin-top: 10px;
      color: white;
      text-decoration: none;
      opacity: 0.7;
    }

    .link:hover {
      opacity: 1;
    }

    /* CONTACT */
    .contact {
      text-align: center;
    }

    .contact p {
      color: #aaa;
      margin-bottom: 20px;
    }

    footer {
      text-align: center;
      padding: 40px;
      color: #555;
    }
  </style>
</head>

<body>

  <nav>
    <div><b>My Portfolio</b></div>
    <div>
      <a href="#portfolio">Projects</a>
      <a href="#contact">Contact</a>
    </div>
  </nav>

  <!-- HERO -->
  <div class="hero">
    <div>
      <div class="subtitle">Frontend Developer</div>
      <h1>I build modern web experiences</h1>
      <p class="description">
        I create fast, clean and responsive websites using HTML, CSS and JavaScript.
      </p>

      <div class="buttons">
        <a class="btn primary" href="#portfolio">View Work</a>
        <a class="btn secondary" href="#contact">Contact</a>
      </div>
    </div>
  </div>

  <!-- PROJECTS -->
  <section id="portfolio">
    <h2>Projects</h2>

    <div class="projects">

      <div class="project-card">
        <img src="https://source.unsplash.com/600x400/?website" />
        <div class="project-info">
          <h3>Landing Page</h3>
          <p>Modern responsive landing page design.</p>
          <div class="tags">
            <span>HTML</span><span>CSS</span><span>JS</span>
          </div>
          <a class="link" href="#">View →</a>
        </div>
      </div>

      <div class="project-card">
        <img src="https://source.unsplash.com/600x400/?app" />
        <div class="project-info">
          <h3>Dashboard UI</h3>
          <p>Clean admin dashboard interface.</p>
          <div class="tags">
            <span>React</span><span>UI</span>
          </div>
          <a class="link" href="#">View →</a>
        </div>
      </div>

      <div class="project-card">
        <img src="https://source.unsplash.com/600x400/?design" />
        <div class="project-info">
          <h3>Portfolio Concept</h3>
          <p>Creative personal branding site.</p>
          <div class="tags">
            <span>Design</span><span>Frontend</span>
          </div>
          <a class="link" href="#">View →</a>
        </div>
      </div>

    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="contact">
    <h2>Contact</h2>
    <p>Want to work together? Let’s build something.</p>
    <a class="btn primary" href="mailto:you@gmail.com">Send Email</a>
  </section>

  <footer>
    © 2026 My Portfolio
  </footer>

  <script>
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add("show");
        }
      });
    });

    document.querySelectorAll(".project-card").forEach(el => {
      observer.observe(el);
    });
  </script>

</body>
</html>
